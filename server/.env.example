# MongoDB
MONGO_URI=mongodb://127.0.0.1:27017/livepoll

# Clerk (Dashboard → API Keys / Webhooks)
CLERK_SECRET_KEY=sk_test_xxxxxxxx
CLERK_WEBHOOK_SECRET=whsec_xxxxxxxx

# Frontend URL (used in poll notification emails)
CLIENT_URL=http://localhost:3000

# Poll auto-close duration in hours
POLL_DURATION_HOURS=12

# Reward credits earned per correct prediction
POLL_REWARD_POINTS=20

# Credits needed to unlock the special milestone reward
MILESTONE_CREDITS=200

# ============================================
# EMAIL (required for real OTP + poll alerts)
# ============================================
# Gmail example — use an App Password, not your regular password:
#   https://myaccount.google.com/apppasswords
#
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your.email@gmail.com
EMAIL_PASS=your_gmail_app_password
EMAIL_FROM="LivePoll <your.email@gmail.com>"

# Other providers:
# Outlook: smtp-mail.outlook.com, port 587
# SendGrid: smtp.sendgrid.net, port 587, user=apikey, pass=YOUR_API_KEY
